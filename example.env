# Copy to .env and fill in. .env is gitignored — NEVER commit the real one.
# Everything personal or secret lives here, so the repo stays publishable.

# Where the private context repo is checked out on this machine
CONTEXT_DIR="$HOME/my-context"

# Claude Code auth for headless runs (choose one strategy):
#   - Subscription: run `claude setup-token` once, or
#   - API key billing:
# ANTHROPIC_API_KEY="sk-ant-..."

# Push notifications (phase 2 — leave unset until ntfy is running).
# The topic name is a de-facto secret: anyone who knows it can push to
# your phone. Pick something long and random.
# NTFY_URL="https://ntfy.example.com"
# NTFY_TOPIC="long-random-string-here"

# Headless run defaults
# FALLBACK ONLY. Each job script exports its own least-privilege tool set, and
# run-agent.sh makes the CALLER win over this value. Do NOT widen this — .env holds
# secrets, not policy. (This line once silently stripped Gmail from the morning brief:
# the brief asked for it, .env took it away, every call was denied, and the model
# reported "0 threads found." Fixed 2026-07-14.)
AGENT_ALLOWED_TOOLS="Read,Glob,Grep"
AGENT_MAX_TURNS=25
AGENT_LOG_DIR="$HOME/.agent-logs"
BACKUP_DIR="$HOME/backups"

# ── GitHub: read Roman's code (see scripts/sync-repos.sh) ────────────────────
# FINE-GRAINED, READ-ONLY, SELECTED REPOS ONLY.
# https://github.com/settings/personal-access-tokens/new
#   Contents=Read-only, Metadata=Read-only, Issues=Read-only, Pull requests=Read-only
#   NOTHING with write access. The agent reads untrusted email and web content while
#   holding shell access; every token it holds is a prompt-injection blast radius.
# GITHUB_TOKEN="github_pat_..."
# GITHUB_REPOS="Roman-Young/PEPMatch2.0 IEDB/PEPMatch Roman-Young/LabReach"
# CODEBASES_DIR="$HOME/agent/codebases"
